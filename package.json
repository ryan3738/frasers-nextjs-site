{
  "name": "frasers-nextjs-site",
  "author": "Ryan Fraser",
  "description": "A website for Frasers Gourmet Hideaway",
  "keywords": [
    "website",
    "nextjs",
    "restaurant"
  ],
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev -p 3100 --experimental-https\"",
    "build": "tinacms build -c \"cross-env NODE_ENV=production next build\"",
    "build:local": "tinacms build --local --skip-cloud-checks -c \"cross-env NODE_ENV=production next build\"",
    "start": "tinacms build -c \"next start\"",
    "ts-lint": "tsc --noEmit --incremental --watch",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@tinacms/auth": "^1.1.3",
    "@tinacms/cli": "^2.4.4",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.3.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "next-tinacms-cloudinary": "^26.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "tinacms": "^3.9.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "postcss": "^8.4.39",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}