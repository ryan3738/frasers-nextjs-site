# TINA SETTINGS
NEXT_PUBLIC_TINA_CLIENT_ID="TINA CLIENT ID"
TINA_TOKEN="TINA TOKEN"
TINA_INDEXER_TOKEN="TINA INDEXER TOKEN"

# Branch Tina reads from and writes to (local dev default)
NEXT_PUBLIC_EDIT_BRANCH="main"

# Optional: force Tina to use a specific branch on Vercel (e.g. "main" when
# preview deploys should not require per-branch Tina Cloud access)
# NEXT_PUBLIC_TINA_BRANCH="main"

# 0 = save to remote git branch (required on Vercel)
# 1 = save to local git branch (local dev only)
NEXT_PUBLIC_USE_LOCAL_CLIENT=1

# Cloudinary API keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="CLOUDINARY CLOUD NAME"
NEXT_PUBLIC_CLOUDINARY_API_KEY="CLOUDINARY API KEY"
CLOUDINARY_API_SECRET="API SECRET"